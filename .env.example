CDN_DIR=".cdn"
LISTEN_HOST="localhost"
LISTEN_PORT="8000"
CN_LISTEN_HOST="127.0.0.1"
CN_LISTEN_PORT="8001"
# 联机 TCP 会话服务器（cooperation_room + cooperation_battle 共用）
SESSION_PORT="8003"
SESSION_HOST="0.0.0.0"
# 公网部署时的 TCP 公网地址（客户端连接用）
# SESSION_PUBLIC_HOST=<YOUR_PUBLIC_IP>
# CN_PUBLIC_HOST=<YOUR_PUBLIC_IP>
# 联机 TCP 会话服务器地址（客户端显示的房间 IP）
# 设为你的 LAN IP（客户端在别的设备时必须设为本机 LAN IP）
# CN_LISTEN_HOST 同时控制 HTTP 绑定和 TCP 显示地址
# 如果客户端在另一台设备上，改 CN_LISTEN_HOST=你的LAN_IP 且同时改 CDN_BASE_URL
# Set this to your LAN IP if client is on another device
CDN_BASE_URL="http://YOUR_LAN_IP:8001/patch/cn"
# 战斗掉落倍数：正常为 1；测试时可调高（如 10）以加速掉落
DROP_MULTIPLIER=1
# 房间自动清理配置
# MULTI_ROOM_EXPIRY_MS=600000         # 空闲房间过期时间（毫秒），默认 10分钟
# MULTI_BATTLE_ROOM_EXPIRY_MS=600000  # 战斗中房间无活动过期时间（毫秒），默认 10分钟
# MULTI_ROOM_CLEAN_INTERVAL_MS=60000   # 过期检查间隔（毫秒），默认 60秒
# SUMMON_COM_SECONDS=5              # 招募后等待召唤的秒数，CDN默认20
# NPC_JOIN_DELAY_MS=2000            # NPC加入房间延迟
# NPC_READY_DELAY_MS=500            # NPC准备延迟
# CN CDN 资源版本号，必须和客户端的 resourceVersion 一致（当前 1.4.54）
CN_RES_VERSION="1.4.54"
